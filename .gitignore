# ==========================================
# BiteBox Master GitIgnore (Monorepo)
# ==========================================

# --- OS Specific ---
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# --- IDEs & Editors ---
.vscode/
.idea/
*.swp
*.swo
*.iml
.project
.settings/

# ==========================================
# bitebox_server (Node.js)
# ==========================================
bitebox_server/node_modules/
bitebox_server/dist/
bitebox_server/build/
bitebox_server/.npm
bitebox_server/.eslintcache
bitebox_server/npm-debug.log*
bitebox_server/yarn-debug.log*
bitebox_server/yarn-error.log*
bitebox_server/.node_repl_history

# Environment Secrets (CRITICAL)
bitebox_server/.env
bitebox_server/.env.local
bitebox_server/.env.development.local
bitebox_server/.env.test.local
bitebox_server/.env.production.local

# ==========================================
# bitebox (Flutter/Dart)
# ==========================================
# Flutter/Dart related
bitebox/.dart_tool/
bitebox/.flutter-plugins
bitebox/.flutter-plugins-dependencies
bitebox/.packages
bitebox/.pub-cache/
bitebox/.pub/
bitebox/build/
bitebox/lib/generated_plugin_registrant.dart

# Android related
bitebox/android/**/gradle-wrapper.jar
bitebox/android/.gradle
bitebox/android/captures/
bitebox/android/gradlew
bitebox/android/gradlew.bat
bitebox/android/key.properties
bitebox/android/local.properties
bitebox/android/**/GeneratedPluginRegistrant.java

# iOS related
bitebox/ios/Flutter/Generated.xcconfig
bitebox/ios/Flutter/app.flx
bitebox/ios/Flutter/app.zip
bitebox/ios/Flutter/flutter_assets/
bitebox/ios/Flutter/flutter_export_environment.sh
bitebox/ios/ServiceDefinitions.json
bitebox/ios/Runner/GeneratedPluginRegistrant.*
bitebox/ios/.generated/
bitebox/ios/.symlinks/
bitebox/ios/Pods/
bitebox/ios/DerivedData/
bitebox/ios/**/xcuserdata

# ==========================================
# MISC
# ==========================================
*.log
logs/
temp/
tmp/