# ==========================================
# BiteBox Master GitIgnore (Monorepo)
# ==========================================

# --- OS Specific ---
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# --- IDEs & Editors ---
.vscode/
.idea/
*.swp
*.swo
*.iml
.project
.settings/

# ==========================================
# BACKEND (Node.js)
# ==========================================
backend/node_modules/
backend/dist/
backend/build/
backend/.npm
backend/.eslintcache
backend/npm-debug.log*
backend/yarn-debug.log*
backend/yarn-error.log*
backend/.node_repl_history

# Environment Secrets (CRITICAL)
backend/.env
backend/.env.local
backend/.env.development.local
backend/.env.test.local
backend/.env.production.local

# ==========================================
# FRONTEND (Flutter/Dart)
# ==========================================
# Flutter/Dart related
frontend/.dart_tool/
frontend/.flutter-plugins
frontend/.flutter-plugins-dependencies
frontend/.packages
frontend/.pub-cache/
frontend/.pub/
frontend/build/
frontend/lib/generated_plugin_registrant.dart

# Android related
frontend/android/**/gradle-wrapper.jar
frontend/android/.gradle
frontend/android/captures/
frontend/android/gradlew
frontend/android/gradlew.bat
frontend/android/key.properties
frontend/android/local.properties
frontend/android/**/GeneratedPluginRegistrant.java

# iOS related
frontend/ios/Flutter/Generated.xcconfig
frontend/ios/Flutter/app.flx
frontend/ios/Flutter/app.zip
frontend/ios/Flutter/flutter_assets/
frontend/ios/Flutter/flutter_export_environment.sh
frontend/ios/ServiceDefinitions.json
frontend/ios/Runner/GeneratedPluginRegistrant.*
frontend/ios/.generated/
frontend/ios/.symlinks/
frontend/ios/Pods/
frontend/ios/DerivedData/
frontend/ios/**/xcuserdata

# ==========================================
# MISC
# ==========================================
*.log
logs/
temp/
tmp/